# GitHub personal access token (required for 5000 req/hr + traffic data)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Libraries.io API key (optional, for richer reverse dependency data)
LIBRARIES_IO_API_KEY=

# Database path (optional, defaults to ./data/gtm-tracker.db)
DATABASE_PATH=

# Slack webhook URL for sales signal alerts (optional, can also be set via Settings UI)
SLACK_WEBHOOK_URL=
